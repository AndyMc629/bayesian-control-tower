# Copy to .env and fill in your values

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Google (Gemini / ADK default) ---
GOOGLE_API_KEY=...

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- Agent defaults ---
# Prefix litellm/ to use a non-Gemini model via LiteLLM
# e.g. litellm/anthropic/claude-sonnet-4-6  or  litellm/openai/gpt-4o
DEFAULT_MODEL=litellm/anthropic/claude-sonnet-4-6
