# Copy to .env and fill in your values

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Google (Gemini / ADK default) ---
GOOGLE_API_KEY=...

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- Agent defaults ---
# ADK model string format (no litellm/ prefix):
#   Anthropic (native):   claude-sonnet-4-6
#   OpenAI (LiteLLM):     openai/gpt-4o
#   Gemini (native):      gemini-2.0-flash
DEFAULT_MODEL=openai/gpt-4o
